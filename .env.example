# انسخي هاد الملف لـ .env وعدّلي القيم قبل التشغيل: cp .env.example .env

# بورت غير شائع افتراضياً — غيّريه لو مشغول عندك بمشروع ثاني
PORT=4471

# سر تشفير الجلسات — لازم يكون طويل وعشوائي. ولّديه بـ: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# خليها production دايماً على السيرفر الحقيقي (خلف nginx+HTTPS) — بتخلي كوكي
# الجلسة "Secure". غيّريها لـ development بس لو عم تجربي محلياً بدون HTTPS.
NODE_ENV=production
